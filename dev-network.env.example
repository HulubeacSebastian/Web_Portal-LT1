# Copiaza ca dev-network.env — configuratie PREDARE Assignment 4 (2 masini, HTTPS).

# CLIENT = masina cu browser + Vite (ex. Mac)
CLIENT_IP=192.168.0.94

# SERVER = masina cu backend Express (ex. PC Windows)
SERVER_IP=192.168.0.81

EXTRA_DEV_IPS=192.168.0.94,192.168.0.81

# Pe masina CLIENT (unde ruleaza Vite)
VITE_LAN_HOST=192.168.0.94

# Cerinta lab: API direct HTTPS catre SERVER (nu proxy HTTP)
VITE_USE_DEV_PROXY=false
BACKEND_HTTP=false

# Evita refresh infinit HMR cross-machine
VITE_DISABLE_HMR=true
