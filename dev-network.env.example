# Copiaza acest fisier ca dev-network.env in radacina proiectului si editeaza IP-urile.
# CLIENT_IP = PC-ul cu browserul (frontend Vite)
# SERVER_IP = PC-ul cu backend Express

CLIENT_IP=192.168.0.94
SERVER_IP=192.168.0.81

# Folosit la generarea certificatelor TLS (ambele IP-uri + localhost)
EXTRA_DEV_IPS=192.168.0.94,192.168.0.81

# HMR: seteaza CLIENT_IP doar daca rulezi frontend pe Mac. Pe PC-ul server lasa comentat.
# VITE_LAN_HOST=192.168.0.94

# Daca pagina se reincarca singura in bucla, decomenteaza:
# VITE_DISABLE_HMR=true
