DATABASE_URL="file:./prisma/dev.db"
PORT=3000

# Masina CLIENT (browser) — HTTPS obligatoriu Assignment 4
ALLOWED_ORIGINS=https://IP_CLIENT:5173

# HTTPS obligatoriu (ruleaza: npm run prepare:dev-tls din radacina proiectului)
SSL_KEY_PATH=certs/dev.key
SSL_CERT_PATH=certs/dev.crt

MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=portal_lt1_chat

# La demo lab: afiseaza OTP in raspuns API (doar dev)
AUTH_EXPOSE_DEV_CODES=true
