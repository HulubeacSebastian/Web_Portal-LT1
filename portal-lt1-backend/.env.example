DATABASE_URL="file:./prisma/dev.db"
PORT=3000

# IP-ul CLIENTULUI (PC-ul unde ruleaza frontend-ul / Vite pe port 5173).
# Pentru HTTPS: https://IP_CLIENT:5173
ALLOWED_ORIGINS=http://IP_CLIENT:5173

# HTTPS (Assignment 4): genereaza certificat cu `npm run cert:generate`, apoi decomenteaza:
# SSL_KEY_PATH=certs/dev.key
# SSL_CERT_PATH=certs/dev.crt

# MongoDB — baza NoSQL pentru chat (Silver)
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=portal_lt1_chat

# OTP / reset token in API response (dev only)
# AUTH_EXPOSE_DEV_CODES=true
