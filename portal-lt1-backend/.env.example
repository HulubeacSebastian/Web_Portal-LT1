# Copiaza:  copy .env.example .env
# Fisierul .env este doar pe fiecare masina (PC / server) — nu intra in git.

DATABASE_URL="file:./prisma/dev.db"
PORT=3000

# --- Varianta PC (dev local, IntelliJ Run) ---
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
PORTAL_DEV_HTTP=true
SSL_KEY_PATH=certs/dev.key
SSL_CERT_PATH=certs/dev.crt

# --- Varianta SERVER Oracle (inlocuieste liniile de mai sus pe VM) ---
# ALLOWED_ORIGINS=https://portal-lt1.duckdns.org
# PORTAL_DEV_HTTP=true
# (fara SSL_KEY_PATH / SSL_CERT_PATH)

MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=portal_lt1_chat
AUTH_EXPOSE_DEV_CODES=true

# --- Email reset parola (optional; daca lipseste, in dev tokenul apare in UI) ---
# PUBLIC_APP_URL=https://portal-lt1.duckdns.org
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-user
# SMTP_PASS=your-password
# MAIL_FROM="Portal LT1 <noreply@lt1.ro>"
