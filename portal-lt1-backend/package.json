    "jsonwebtoken": "^9.0.2",
    "morgan": "~1.9.1",
    "ws": "^8.18.3",
    "@faker-js/faker": "^9.9.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "prisma": "^6.8.2",
    "supertest": "^7.1.4"
  }
}
