# Optional: copiaza dev-network.env in radacina proiectului (SERVER_IP / CLIENT_IP).
# Vite foloseste automat https://SERVER_IP:3000 daca lipseste VITE_API_BASE_URL.
#
# Suprascriere manuala:
# VITE_API_BASE_URL=https://IP_SERVER:3000

# Logout automat dupa inactivitate (ms). Implicit: 30 minute.
# VITE_SESSION_IDLE_MS=1800000
