# IP-ul SERVERULUI (PC-ul unde ruleaza backend-ul pe port 3000).
# Pentru HTTPS (Assignment 4) — inlocuieste IP_SERVER cu IP-ul PC-ului backend:
VITE_API_BASE_URL=https://IP_SERVER:3000

# Exemplu retea locala (PC client 192.168.0.94, PC server 192.168.0.81):
# VITE_API_BASE_URL=https://192.168.0.81:3000

# Logout automat dupa inactivitate (ms). Implicit: 30 minute.
# VITE_SESSION_IDLE_MS=1800000
