# Fisier .env pe masina CLIENT (browser) — nu pe SERVER.

# IP-ul masinii SERVER (backend HTTPS port 3000)
VITE_API_BASE_URL=https://IP_SERVER:3000

# Exemplu: VITE_API_BASE_URL=https://192.168.0.81:3000

# Logout dupa inactivitate (ms). 60000 = 1 minut pentru test la lab.
# VITE_SESSION_IDLE_MS=1800000
