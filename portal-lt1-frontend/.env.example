# IP-ul SERVERULUI (PC-ul unde ruleaza backend-ul pe port 3000).
VITE_API_BASE_URL=http://IP_SERVER:3000

# HTTPS: https://IP_SERVER:3000 (backend cu SSL_KEY_PATH / SSL_CERT_PATH in .env)
# Frontend HTTPS: npm run dev:https

# Logout automat dupa inactivitate (ms). Implicit: 30 minute.
# VITE_SESSION_IDLE_MS=1800000
