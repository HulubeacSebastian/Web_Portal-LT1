{
  "name": "portal-lt1-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:local": "cross-env VITE_USE_DEV_PROXY=true VITE_PROXY_TARGET=http://127.0.0.1:3000 vite",
    "dev:https": "node ../portal-lt1-backend/scripts/prepare-dev-tls.js && node scripts/run-vite-dev.mjs",
    "dev:client": "node ../portal-lt1-backend/scripts/prepare-dev-tls.js && node scripts/run-vite-dev.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "preview:https": "npm run build && cross-env VITE_DEV_HTTPS=true vite preview --host 0.0.0.0",
    "test": "vitest run --config ../portal-lt1-Tests/frontend/vitest.config.cjs",
    "test:coverage": "vitest run --config ../portal-lt1-Tests/frontend/vitest.config.cjs --coverage",
    "test:watch": "vitest --config ../portal-lt1-Tests/frontend/vitest.config.cjs",
    "test:e2e": "playwright test --config ../portal-lt1-Tests/frontend/playwright.config.cjs"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@vitejs/plugin-basic-ssl": "^1.2.0",
    "@vitejs/plugin-react": "^4.3.2",
    "@vitest/coverage-v8": "^2.1.9",
    "cross-env": "^7.0.3",
    "jsdom": "^25.0.1",
    "vite": "^5.4.8",
    "vitest": "^2.1.2"
  }
}
